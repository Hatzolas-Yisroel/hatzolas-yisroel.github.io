                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "WhatsApp (Logistic Response)",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Sefaria API (Extract Halacha)": {
            "main": [
                [
                    {
                        "node": "WhatsApp (Sefaria Response)",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "active": false,
    "settings": {}
}